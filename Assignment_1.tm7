g></b:Value><b:SelectedIndex>0</b:SelectedIndex></a:anyType><a:anyType i:type="b:ListDisplayAttribute" xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:DisplayName>Forgery Protection</b:DisplayName><b:Name>54851a3b-65da-4902-b4e0-94ef015be735</b:Name><b:Value i:type="a:ArrayOfstring"><a:string>Not Selected</a:string><a:string>ValidateAntiForgeryTokenAttribute</a:string><a:string>ViewStateUserKey</a:string><a:string>Nonce</a:string><a:string>Other dynamic canary</a:string><a:string>Static header not available to the browser</a:string><a:string>Other</a:string><a:string>None</a:string><a:string>Not applicable because the request does not change data</a:string></b:Value><b:SelectedIndex>0</b:SelectedIndex></a:anyType></Properties><TypeId xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">SE.DF.TMCore.Binary</TypeId><HandleX xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">672</HandleX><HandleY xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">785</HandleY><PortSource xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">NorthEast</PortSource><PortTarget xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">SouthWest</PortTarget><SourceGuid xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">de3f295a-bca5-4e40-a1f6-18648a39555c</SourceGuid><SourceX xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">632</SourceX><SourceY xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">840</SourceY><TargetGuid xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">3ad70b89-cbaa-46da-90af-60b39866725b</TargetGuid><TargetX xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">645</TargetX><TargetY xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">600</TargetY></a:Value></a:KeyValueOfguidanyType></Lines><Zoom>1.25</Zoom></DrawingSurfaceModel></DrawingSurfaceList><MetaInformation><Assumptions/><Contributors/><ExternalDependencies/><HighLevelSystemDescription/><Owner/><Reviewer/><ThreatModelName/></MetaInformation><Notes/><ThreatInstances xmlns:a="http://schemas.microsoft.com/2003/10/Serialization/Arrays"><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S32fee6239-2740-4c3e-bb93-9984dd99fc7e9d897276-80f7-4a63-8a7b-0af44e2ff0c5852b9584-943b-4a59-84e6-a3ebd7414d35</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>9d897276-80f7-4a63-8a7b-0af44e2ff0c5</b:FlowGuid><b:Id>119</b:Id><b:InteractionKey>2fee6239-2740-4c3e-bb93-9984dd99fc7e:9d897276-80f7-4a63-8a7b-0af44e2ff0c5:852b9584-943b-4a59-84e6-a3ebd7414d35</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing the Browser External Entity</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Browser may be spoofed by an attacker and this may lead to unauthorized access to Content Delivery Network/ web Appl Firewall. Consider using a standard authentication mechanism to identify the external entity.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectiona</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>2fee6239-2740-4c3e-bb93-9984dd99fc7e</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>852b9584-943b-4a59-84e6-a3ebd7414d35</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S3</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E52fee6239-2740-4c3e-bb93-9984dd99fc7e9d897276-80f7-4a63-8a7b-0af44e2ff0c5852b9584-943b-4a59-84e6-a3ebd7414d35</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>9d897276-80f7-4a63-8a7b-0af44e2ff0c5</b:FlowGuid><b:Id>1</b:Id><b:InteractionKey>2fee6239-2740-4c3e-bb93-9984dd99fc7e:9d897276-80f7-4a63-8a7b-0af44e2ff0c5:852b9584-943b-4a59-84e6-a3ebd7414d35</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:09:49.7087986-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Elevation Using Impersonation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Content Delivery Network/ web Appl Firewall may be able to impersonate the context of Browser in order to gain additional privilege.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>After studying the STRIDE framework, I determined that to prevent users from gaining access beyond their role, the system should enforce Role-Based Access Control (RBAC) on the server side and never trust role information sent by the client. Applied the principle of least privilege so each user only gets the minimum access they need. (Microsoft STRIDE Threat Modeling Framework, learn.microsoft.com, 2022) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectiona</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>2fee6239-2740-4c3e-bb93-9984dd99fc7e</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>852b9584-943b-4a59-84e6-a3ebd7414d35</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E5</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T2852b9584-943b-4a59-84e6-a3ebd7414d35271ed95d-a951-45fd-8760-c0560fc63b005ff87fa8-86d3-4a55-9f50-262e41fa71fc</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>271ed95d-a951-45fd-8760-c0560fc63b00</b:FlowGuid><b:Id>7</b:Id><b:InteractionKey>852b9584-943b-4a59-84e6-a3ebd7414d35:271ed95d-a951-45fd-8760-c0560fc63b00:5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:10:27.3176748-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>CDN / WAF Process Memory Tampered</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Tampering is the act of altering the bits. Tampering with a process involves changing bits in the running process. Similarly, Tampering with a data flow involves changing bits on the wire or between two running processes.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>If Content Delivery Network/ web Appl Firewall is given access to memory, such as shared memory or pointers, or is given the ability to control what API Gateway executes (for example, passing back a function pointer.), then Content Delivery Network/ web Appl Firewall can tamper with API Gateway. Consider if the function could work with less access to memory, such as passing data rather than pointers. Copy in data provided, and then validate it.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Realized the CDN/WAF layer could be a target for data tampering if connections are not encrypted. Decided to enforce TLS 1.2 or higher on all CDN connections and apply HSTS headers so browsers always use encrypted connections. The WAF also filters known tampering attack patterns before they reach the backend. (AWS Well-Architected Framework Security Pillar, aws.amazon.com, 2023)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>852b9584-943b-4a59-84e6-a3ebd7414d35</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T2</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E3917996b7-6cd4-4ecf-88cd-aa37bea4c160a5c259b6-a28d-4391-bccd-7d358148f043bf23a18b-7057-44eb-b3a8-80b8d3bc9a18</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>a5c259b6-a28d-4391-bccd-7d358148f043</b:FlowGuid><b:Id>6</b:Id><b:InteractionKey>917996b7-6cd4-4ecf-88cd-aa37bea4c160:a5c259b6-a28d-4391-bccd-7d358148f043:bf23a18b-7057-44eb-b3a8-80b8d3bc9a18</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:09:44.7675396-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Weakness in SSO Authorization</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Common SSO implementations such as OAUTH2 and OAUTH Wrap are vulnerable to MitM attacks.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Researched that weak SSO implementations are a common entry point for privilege escalation. Solution was to use OAuth 2.0 with PKCE which removes the authorization code interception risk, combined with HttpOnly and Secure cookie flags to protect session tokens from being stolen via browser scripts. (OWASP Top 10, owasp.org, 2021)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>917996b7-6cd4-4ecf-88cd-aa37bea4c160</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>bf23a18b-7057-44eb-b3a8-80b8d3bc9a18</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E3</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S3983264e1-020a-4a51-841b-f848f8b2e5d64f2fb21a-dca5-49d6-b1e1-dca73f7fdc535ff87fa8-86d3-4a55-9f50-262e41fa71fc</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>4f2fb21a-dca5-49d6-b1e1-dca73f7fdc53</b:FlowGuid><b:Id>4</b:Id><b:InteractionKey>983264e1-020a-4a51-841b-f848f8b2e5d6:4f2fb21a-dca5-49d6-b1e1-dca73f7fdc53:5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:09:53.6206459-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing the Mobile App External Entity</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Mobile App may be spoofed by an attacker and this may lead to unauthorized access to API Gateway. Consider using a standard authentication mechanism to identify the external entity.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified that a Mobile App user could be impersonated if authentication is weak. To address this, implemented Multi-Factor Authentication (MFA) and OAuth 2.0 with PKCE, along with short-lived JWT tokens that expire after 15 minutes. This way even if a token is stolen, it becomes useless quickly. (OWASP Threat Modeling Process, owasp.org, 2024)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>983264e1-020a-4a51-841b-f848f8b2e5d6</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S3</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E5983264e1-020a-4a51-841b-f848f8b2e5d64f2fb21a-dca5-49d6-b1e1-dca73f7fdc535ff87fa8-86d3-4a55-9f50-262e41fa71fc</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>4f2fb21a-dca5-49d6-b1e1-dca73f7fdc53</b:FlowGuid><b:Id>5</b:Id><b:InteractionKey>983264e1-020a-4a51-841b-f848f8b2e5d6:4f2fb21a-dca5-49d6-b1e1-dca73f7fdc53:5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:09:56.6118234-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Elevation Using Impersonation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>API Gateway may be able to impersonate the context of Mobile App in order to gain additional privilege.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Found that the API Gateway could be exploited to gain higher privileges if role validation is done on the client side. Mitigation was to move all authorization checks to the server side and use separate signed tokens for admin operations so regular users cannot forge elevated access. (Microsoft STRIDE Threat Modeling Framework, learn.microsoft.com, 2022)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>983264e1-020a-4a51-841b-f848f8b2e5d6</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E5</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E5852b9584-943b-4a59-84e6-a3ebd7414d35271ed95d-a951-45fd-8760-c0560fc63b005ff87fa8-86d3-4a55-9f50-262e41fa71fc</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>271ed95d-a951-45fd-8760-c0560fc63b00</b:FlowGuid><b:Id>8</b:Id><b:InteractionKey>852b9584-943b-4a59-84e6-a3ebd7414d35:271ed95d-a951-45fd-8760-c0560fc63b00:5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:10:52.3167018-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Elevation Using Impersonation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>API Gateway may be able to impersonate the context of Content Delivery Network/ web Appl Firewall in order to gain additional privilege.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified that the API Gateway routing logic could be abused to access privileged operations. Mitigation was to enforce server-side authorization at every route, rejecting any request that does not carry a valid, server-verified token with the correct permissions. (Microsoft STRIDE Threat Modeling Framework, learn.microsoft.com, 2022)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>852b9584-943b-4a59-84e6-a3ebd7414d35</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E5</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T25ff87fa8-86d3-4a55-9f50-262e41fa71fc7c2d94e6-fd47-43dd-a09c-6248ea07e0a1832b5c7f-fd8d-4c47-af6b-ea0fd006da01</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>7c2d94e6-fd47-43dd-a09c-6248ea07e0a1</b:FlowGuid><b:Id>9</b:Id><b:InteractionKey>5ff87fa8-86d3-4a55-9f50-262e41fa71fc:7c2d94e6-fd47-43dd-a09c-6248ea07e0a1:832b5c7f-fd8d-4c47-af6b-ea0fd006da01</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:11:45.4897973-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>API Gateway Process Memory Tampered</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Tampering is the act of altering the bits. Tampering with a process involves changing bits in the running process. Similarly, Tampering with a data flow involves changing bits on the wire or between two running processes.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>If API Gateway is given access to memory, such as shared memory or pointers, or is given the ability to control what Load Balancer executes (for example, passing back a function pointer.), then API Gateway can tamper with Load Balancer. Consider if the function could work with less access to memory, such as passing data rather than pointers. Copy in data provided, and then validate it.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Determined that data flowing through the API Gateway could be modified in transit. To prevent this, enforced TLS 1.2+ on all connections and added SHA-256 integrity checksums on payloads so any modification between sender and receiver can be detected. (NIST SP 800-209 Security Guidelines for Storage, nvlpubs.nist.gov, 2020)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>832b5c7f-fd8d-4c47-af6b-ea0fd006da01</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T2</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E55ff87fa8-86d3-4a55-9f50-262e41fa71fc7c2d94e6-fd47-43dd-a09c-6248ea07e0a1832b5c7f-fd8d-4c47-af6b-ea0fd006da01</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>7c2d94e6-fd47-43dd-a09c-6248ea07e0a1</b:FlowGuid><b:Id>10</b:Id><b:InteractionKey>5ff87fa8-86d3-4a55-9f50-262e41fa71fc:7c2d94e6-fd47-43dd-a09c-6248ea07e0a1:832b5c7f-fd8d-4c47-af6b-ea0fd006da01</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:12:49.2664209-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Elevation Using Impersonation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Load Balancer may be able to impersonate the context of API Gateway in order to gain additional privilege.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Found that the Load Balancer could become a path for privilege escalation if it routes unvalidated requests. Mitigation was to ensure the Load Balancer only routes requests that have already passed authentication at the API Gateway, and that RBAC is enforced on every downstream service. (Microsoft STRIDE Threat Modeling Framework, learn.microsoft.com, 2022)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>832b5c7f-fd8d-4c47-af6b-ea0fd006da01</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E5</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T25ff87fa8-86d3-4a55-9f50-262e41fa71fc663b907d-10c2-4dcc-bb8a-7834c5bf1b84290fd120-69d8-46a1-8b55-f5f0b4a8229d</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>663b907d-10c2-4dcc-bb8a-7834c5bf1b84</b:FlowGuid><b:Id>11</b:Id><b:InteractionKey>5ff87fa8-86d3-4a55-9f50-262e41fa71fc:663b907d-10c2-4dcc-bb8a-7834c5bf1b84:290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:13:03.2806636-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>API Gateway Process Memory Tampered</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Tampering is the act of altering the bits. Tampering with a process involves changing bits in the running process. Similarly, Tampering with a data flow involves changing bits on the wire or between two running processes.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>If API Gateway is given access to memory, such as shared memory or pointers, or is given the ability to control what File Upload/Download API executes (for example, passing back a function pointer.), then API Gateway can tamper with File Upload/Download API. Consider if the function could work with less access to memory, such as passing data rather than pointers. Copy in data provided, and then validate it.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Similar to threat 9, applied TLS 1.2+ and HSTS headers on all API Gateway connections to prevent man-in-the-middle tampering. SHA-256 checksums validate that data has not been altered between the client and the server. (NIST SP 800-209, nvlpubs.nist.gov, 2020)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T2</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E55ff87fa8-86d3-4a55-9f50-262e41fa71fc663b907d-10c2-4dcc-bb8a-7834c5bf1b84290fd120-69d8-46a1-8b55-f5f0b4a8229d</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>663b907d-10c2-4dcc-bb8a-7834c5bf1b84</b:FlowGuid><b:Id>12</b:Id><b:InteractionKey>5ff87fa8-86d3-4a55-9f50-262e41fa71fc:663b907d-10c2-4dcc-bb8a-7834c5bf1b84:290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:13:34.7703973-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Elevation Using Impersonation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>File Upload/Download API may be able to impersonate the context of API Gateway in order to gain additional privilege.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified that the File Upload/Download API could be exploited to access files belonging to other users. Mitigated this by enforcing ownership-based access control and using pre-signed URLs that are tied to the requesting user's identity, so no one can access another user's files. (OWASP Top 10, owasp.org, 2021)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E5</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T2832b5c7f-fd8d-4c47-af6b-ea0fd006da0145448a19-eeda-4947-ab9c-1129f17395744be9d095-d0d8-4a18-88a4-d518f1fc04ac</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>45448a19-eeda-4947-ab9c-1129f1739574</b:FlowGuid><b:Id>13</b:Id><b:InteractionKey>832b5c7f-fd8d-4c47-af6b-ea0fd006da01:45448a19-eeda-4947-ab9c-1129f1739574:4be9d095-d0d8-4a18-88a4-d518f1fc04ac</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:14:08.3848255-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Load Balancer Process Memory Tampered</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Tampering is the act of altering the bits. Tampering with a process involves changing bits in the running process. Similarly, Tampering with a data flow involves changing bits on the wire or between two running processes.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>If Load Balancer is given access to memory, such as shared memory or pointers, or is given the ability to control what Access Control executes (for example, passing back a function pointer.), then Load Balancer can tamper with Access Control. Consider if the function could work with less access to memory, such as passing data rather than pointers. Copy in data provided, and then validate it.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Determined that data passing through the Load Balancer could be tampered with if the connection is unencrypted. Solution was to enforce TLS 1.2+ on all internal connections from the Load Balancer to backend services, preventing any modification of data in transit. (NIST SP 800-209, nvlpubs.nist.gov, 2020)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>832b5c7f-fd8d-4c47-af6b-ea0fd006da01</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>4be9d095-d0d8-4a18-88a4-d518f1fc04ac</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T2</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E5832b5c7f-fd8d-4c47-af6b-ea0fd006da0145448a19-eeda-4947-ab9c-1129f17395744be9d095-d0d8-4a18-88a4-d518f1fc04ac</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>45448a19-eeda-4947-ab9c-1129f1739574</b:FlowGuid><b:Id>14</b:Id><b:InteractionKey>832b5c7f-fd8d-4c47-af6b-ea0fd006da01:45448a19-eeda-4947-ab9c-1129f1739574:4be9d095-d0d8-4a18-88a4-d518f1fc04ac</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:14:37.3908971-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Elevation Using Impersonation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Access Control may be able to impersonate the context of Load Balancer in order to gain additional privilege.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Found the Access Control module needs to verify ownership on every single file operation, not just at login. Applied row-level security in the database and made sure RBAC is checked server-side independently of anything the client sends. (OWASP Top 10, owasp.org, 2021)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>832b5c7f-fd8d-4c47-af6b-ea0fd006da01</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>4be9d095-d0d8-4a18-88a4-d518f1fc04ac</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E5</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T2290fd120-69d8-46a1-8b55-f5f0b4a8229d0bf68dfa-0547-49a5-ab36-1195a7e8ca4c43dde1f5-b640-4a11-abcd-ff234abc8f71</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>0bf68dfa-0547-49a5-ab36-1195a7e8ca4c</b:FlowGuid><b:Id>15</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:0bf68dfa-0547-49a5-ab36-1195a7e8ca4c:43dde1f5-b640-4a11-abcd-ff234abc8f71</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:15:53.1564609-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>File Upload/Download API Process Memory Tampered</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Tampering is the act of altering the bits. Tampering with a process involves changing bits in the running process. Similarly, Tampering with a data flow involves changing bits on the wire or between two running processes.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>If File Upload/Download API is given access to memory, such as shared memory or pointers, or is given the ability to control what Virus Scanner  executes (for example, passing back a function pointer.), then File Upload/Download API can tamper with Virus Scanner . Consider if the function could work with less access to memory, such as passing data rather than pointers. Copy in data provided, and then validate it.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Studied that uploaded files could be tampered with during transit or at rest. Mitigation was to compute SHA-256 checksums at upload and verify them at download, plus encrypt all files at rest using AES-256 via KMS. I also added MIME-type magic byte validation to detect disguised malicious files. (NIST SP 800-209, nvlpubs.nist.gov, 2020)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>43dde1f5-b640-4a11-abcd-ff234abc8f71</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T2</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E5290fd120-69d8-46a1-8b55-f5f0b4a8229d0bf68dfa-0547-49a5-ab36-1195a7e8ca4c43dde1f5-b640-4a11-abcd-ff234abc8f71</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>0bf68dfa-0547-49a5-ab36-1195a7e8ca4c</b:FlowGuid><b:Id>16</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:0bf68dfa-0547-49a5-ab36-1195a7e8ca4c:43dde1f5-b640-4a11-abcd-ff234abc8f71</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:16:45.3174381-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Elevation Using Impersonation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Virus Scanner  may be able to impersonate the context of File Upload/Download API in order to gain additional privilege.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Recognized the Virus Scanner could be a target if it runs with too many permissions. Mitigation was to run the scanner in an isolated sandbox environment with a least-privilege service account so even if it is compromised, the attacker cannot move laterally into the rest of the system. (Microsoft STRIDE Threat Modeling Framework, learn.microsoft.com, 2022)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>43dde1f5-b640-4a11-abcd-ff234abc8f71</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E5</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T2290fd120-69d8-46a1-8b55-f5f0b4a8229dd0ca1a7b-1082-4111-a590-e454b9b826153ad70b89-cbaa-46da-90af-60b39866725b</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>d0ca1a7b-1082-4111-a590-e454b9b82615</b:FlowGuid><b:Id>17</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:d0ca1a7b-1082-4111-a590-e454b9b82615:3ad70b89-cbaa-46da-90af-60b39866725b</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:17:07.1142101-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>File Upload/Download API Process Memory Tampered</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Tampering is the act of altering the bits. Tampering with a process involves changing bits in the running process. Similarly, Tampering with a data flow involves changing bits on the wire or between two running processes.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>If File Upload/Download API is given access to memory, such as shared memory or pointers, or is given the ability to control what Audit Logger executes (for example, passing back a function pointer.), then File Upload/Download API can tamper with Audit Logger. Consider if the function could work with less access to memory, such as passing data rather than pointers. Copy in data provided, and then validate it.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Applied the same file integrity controls as threat 15 — SHA-256 checksums and AES-256 encryption. Also made sure files are stored outside the web root so they cannot be accessed or modified directly through a browser URL. (NIST SP 800-209, nvlpubs.nist.gov, 2020) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>3ad70b89-cbaa-46da-90af-60b39866725b</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T2</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E5290fd120-69d8-46a1-8b55-f5f0b4a8229dd0ca1a7b-1082-4111-a590-e454b9b826153ad70b89-cbaa-46da-90af-60b39866725b</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>d0ca1a7b-1082-4111-a590-e454b9b82615</b:FlowGuid><b:Id>18</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:d0ca1a7b-1082-4111-a590-e454b9b82615:3ad70b89-cbaa-46da-90af-60b39866725b</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:17:25.8825681-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Elevation Using Impersonation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Audit Logger may be able to impersonate the context of File Upload/Download API in order to gain additional privilege.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Determined that the Audit Logger must operate in write-only mode with no path back to privileged operations. Assigned it a least-privilege service account and made sure it has no admin-level access to any other part of the system. (Microsoft STRIDE Threat Modeling Framework, learn.microsoft.com, 2022) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>3ad70b89-cbaa-46da-90af-60b39866725b</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E5</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E54be9d095-d0d8-4a18-88a4-d518f1fc04ac9476e044-21b7-4cad-9e24-c32f84e43269b0fe5995-7340-46c7-a2f6-6a0a84bd1bd3</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>9476e044-21b7-4cad-9e24-c32f84e43269</b:FlowGuid><b:Id>122</b:Id><b:InteractionKey>4be9d095-d0d8-4a18-88a4-d518f1fc04ac:9476e044-21b7-4cad-9e24-c32f84e43269:b0fe5995-7340-46c7-a2f6-6a0a84bd1bd3</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Elevation Using Impersonation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Notification Service may be able to impersonate the context of Access Control in order to gain additional privilege.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS biirectional </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>4be9d095-d0d8-4a18-88a4-d518f1fc04ac</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>b0fe5995-7340-46c7-a2f6-6a0a84bd1bd3</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E5</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T24be9d095-d0d8-4a18-88a4-d518f1fc04ac9476e044-21b7-4cad-9e24-c32f84e43269b0fe5995-7340-46c7-a2f6-6a0a84bd1bd3</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>9476e044-21b7-4cad-9e24-c32f84e43269</b:FlowGuid><b:Id>121</b:Id><b:InteractionKey>4be9d095-d0d8-4a18-88a4-d518f1fc04ac:9476e044-21b7-4cad-9e24-c32f84e43269:b0fe5995-7340-46c7-a2f6-6a0a84bd1bd3</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Access Control Process Memory Tampered</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Tampering is the act of altering the bits. Tampering with a process involves changing bits in the running process. Similarly, Tampering with a data flow involves changing bits on the wire or between two running processes.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>If Access Control is given access to memory, such as shared memory or pointers, or is given the ability to control what Notification Service executes (for example, passing back a function pointer.), then Access Control can tamper with Notification Service. Consider if the function could work with less access to memory, such as passing data rather than pointers. Copy in data provided, and then validate it.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS biirectional </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>4be9d095-d0d8-4a18-88a4-d518f1fc04ac</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>b0fe5995-7340-46c7-a2f6-6a0a84bd1bd3</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T2</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S7.1290fd120-69d8-46a1-8b55-f5f0b4a8229d8f075b78-4e76-4f94-a4ae-7805b5195bd539c51d12-c6ef-4824-9e7d-6baec5737118</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>8f075b78-4e76-4f94-a4ae-7805b5195bd5</b:FlowGuid><b:Id>21</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:8f075b78-4e76-4f94-a4ae-7805b5195bd5:39c51d12-c6ef-4824-9e7d-6baec5737118</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:17:50.0047442-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing of Destination Data Store Cloud Storage</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Cloud Storage may be spoofed by an attacker and this may lead to data being written to the attacker's target instead of Cloud Storage. Consider using a standard authentication mechanism to identify the destination data store.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Found that Cloud Storage buckets being publicly accessible is one of the most dangerous misconfigurations possible. Mitigation was to enforce S3 Block Public Access and Azure Blob private container policies by default, and use pre-signed URLs that are tied to verified user identity for all file access. (OWASP Top 10, owasp.org, 2021) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary biriectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>39c51d12-c6ef-4824-9e7d-6baec5737118</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S7.1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D2290fd120-69d8-46a1-8b55-f5f0b4a8229d8f075b78-4e76-4f94-a4ae-7805b5195bd539c51d12-c6ef-4824-9e7d-6baec5737118</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>8f075b78-4e76-4f94-a4ae-7805b5195bd5</b:FlowGuid><b:Id>22</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:8f075b78-4e76-4f94-a4ae-7805b5195bd5:39c51d12-c6ef-4824-9e7d-6baec5737118</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:18:07.8309703-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential Excessive Resource Consumption for File Upload/Download API or Cloud Storage</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Does File Upload/Download API or Cloud Storage take explicit steps to control resource consumption? Resource consumption attacks can be hard to deal with, and there are times that it makes sense to let the OS do the job. Be careful that your resource requests don't deadlock, and that they do timeout.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified that an attacker could flood the file upload endpoint to exhaust storage. Mitigated this by setting a 100MB maximum file size, enforcing API Gateway rate limiting at 100 requests per minute per user, and applying per-user storage quotas so one account cannot consume all available space. (AWS Well-Architected Framework Security Pillar, aws.amazon.com, 2023) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary biriectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>39c51d12-c6ef-4824-9e7d-6baec5737118</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D2</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S7.13ad70b89-cbaa-46da-90af-60b39866725b94d3f073-29ee-451b-afac-21abcbaa34aff7ebb07c-e60a-4a98-8049-bfaa7a109a15</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>94d3f073-29ee-451b-afac-21abcbaa34af</b:FlowGuid><b:Id>23</b:Id><b:InteractionKey>3ad70b89-cbaa-46da-90af-60b39866725b:94d3f073-29ee-451b-afac-21abcbaa34af:f7ebb07c-e60a-4a98-8049-bfaa7a109a15</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:18:24.3840662-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing of Destination Data Store Audit Log Store</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Audit Log Store may be spoofed by an attacker and this may lead to data being written to the attacker's target instead of Audit Log Store. Consider using a standard authentication mechanism to identify the destination data store.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Recognized that the Audit Log Store could be targeted to inject fake log entries. Mitigation was to restrict write access to a dedicated write-only service account and sign all log entries with HMAC so any forged or tampered entry can be detected. (OWASP Threat Modeling Process, owasp.org, 2024) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>3ad70b89-cbaa-46da-90af-60b39866725b</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>f7ebb07c-e60a-4a98-8049-bfaa7a109a15</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S7.1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T73ad70b89-cbaa-46da-90af-60b39866725b94d3f073-29ee-451b-afac-21abcbaa34aff7ebb07c-e60a-4a98-8049-bfaa7a109a15</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>94d3f073-29ee-451b-afac-21abcbaa34af</b:FlowGuid><b:Id>24</b:Id><b:InteractionKey>3ad70b89-cbaa-46da-90af-60b39866725b:94d3f073-29ee-451b-afac-21abcbaa34af:f7ebb07c-e60a-4a98-8049-bfaa7a109a15</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:18:40.8617538-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential SQL Injection Vulnerability for Audit Log Store</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Tampering is the act of altering the bits. Tampering with a process involves changing bits in the running process. Similarly, Tampering with a data flow involves changing bits on the wire or between two running processes.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>SQL injection is an attack in which malicious code is inserted into strings that are later passed to an instance of SQL Server for parsing and execution. Any procedure that constructs SQL statements should be reviewed for injection vulnerabilities because SQL Server will execute all syntactically valid queries that it receives. Even parameterized data can be manipulated by a skilled and determined attacker.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Determined the Audit Log Store database is vulnerable to SQL injection if queries are built dynamically. Solution was to enforce parameterized queries through an ORM for all database operations, and validate all input at the API layer before it reaches the database. (NIST SP 800-209, nvlpubs.nist.gov, 2020) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>3ad70b89-cbaa-46da-90af-60b39866725b</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>f7ebb07c-e60a-4a98-8049-bfaa7a109a15</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T7</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D23ad70b89-cbaa-46da-90af-60b39866725b94d3f073-29ee-451b-afac-21abcbaa34aff7ebb07c-e60a-4a98-8049-bfaa7a109a15</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>94d3f073-29ee-451b-afac-21abcbaa34af</b:FlowGuid><b:Id>25</b:Id><b:InteractionKey>3ad70b89-cbaa-46da-90af-60b39866725b:94d3f073-29ee-451b-afac-21abcbaa34af:f7ebb07c-e60a-4a98-8049-bfaa7a109a15</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:19:00.1841385-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential Excessive Resource Consumption for Audit Logger or Audit Log Store</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Does Audit Logger or Audit Log Store take explicit steps to control resource consumption? Resource consumption attacks can be hard to deal with, and there are times that it makes sense to let the OS do the job. Be careful that your resource requests don't deadlock, and that they do timeout.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified that the Audit Log Store could be overwhelmed by a flood of write operations. Mitigation included rate limiting on log write operations, CDN/WAF DDoS absorption at the perimeter, and multi-region replication to maintain availability even under attack. (AWS Well-Architected Framework Security Pillar, aws.amazon.com, 2023) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>3ad70b89-cbaa-46da-90af-60b39866725b</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>f7ebb07c-e60a-4a98-8049-bfaa7a109a15</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D2</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S7.13ad70b89-cbaa-46da-90af-60b39866725bb2aa3fe4-c192-4720-8393-d3e3051e4df9a04d8cf3-64f7-4a0f-a673-269ca42890dc</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>b2aa3fe4-c192-4720-8393-d3e3051e4df9</b:FlowGuid><b:Id>26</b:Id><b:InteractionKey>3ad70b89-cbaa-46da-90af-60b39866725b:b2aa3fe4-c192-4720-8393-d3e3051e4df9:a04d8cf3-64f7-4a0f-a673-269ca42890dc</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:19:43.6730988-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing of Destination Data Store MetaData Database</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>MetaData Database may be spoofed by an attacker and this may lead to data being written to the attacker's target instead of MetaData Database. Consider using a standard authentication mechanism to identify the destination data store.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Found that the MetaData Database could be accessed by unauthorized services if not properly isolated. Mitigated this by restricting access to authenticated internal services only and applying row-level security. Priority is Medium because metadata does not contain actual file content or encryption keys. (OWASP Top 10, owasp.org, 2021) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Medium</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>3ad70b89-cbaa-46da-90af-60b39866725b</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>a04d8cf3-64f7-4a0f-a673-269ca42890dc</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S7.1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T73ad70b89-cbaa-46da-90af-60b39866725bb2aa3fe4-c192-4720-8393-d3e3051e4df9a04d8cf3-64f7-4a0f-a673-269ca42890dc</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>b2aa3fe4-c192-4720-8393-d3e3051e4df9</b:FlowGuid><b:Id>27</b:Id><b:InteractionKey>3ad70b89-cbaa-46da-90af-60b39866725b:b2aa3fe4-c192-4720-8393-d3e3051e4df9:a04d8cf3-64f7-4a0f-a673-269ca42890dc</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:19:41.0897663-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential SQL Injection Vulnerability for MetaData Database</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Tampering is the act of altering the bits. Tampering with a process involves changing bits in the running process. Similarly, Tampering with a data flow involves changing bits on the wire or between two running processes.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>SQL injection is an attack in which malicious code is inserted into strings that are later passed to an instance of SQL Server for parsing and execution. Any procedure that constructs SQL statements should be reviewed for injection vulnerabilities because SQL Server will execute all syntactically valid queries that it receives. Even parameterized data can be manipulated by a skilled and determined attacker.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Applied parameterized queries via ORM to prevent SQL injection on the MetaData Database. Priority is Medium because while metadata tampering could affect access decisions, it does not directly expose file content or credentials. (NIST SP 800-209, nvlpubs.nist.gov, 2020) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Medium</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>3ad70b89-cbaa-46da-90af-60b39866725b</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>a04d8cf3-64f7-4a0f-a673-269ca42890dc</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T7</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D23ad70b89-cbaa-46da-90af-60b39866725bb2aa3fe4-c192-4720-8393-d3e3051e4df9a04d8cf3-64f7-4a0f-a673-269ca42890dc</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>b2aa3fe4-c192-4720-8393-d3e3051e4df9</b:FlowGuid><b:Id>28</b:Id><b:InteractionKey>3ad70b89-cbaa-46da-90af-60b39866725b:b2aa3fe4-c192-4720-8393-d3e3051e4df9:a04d8cf3-64f7-4a0f-a673-269ca42890dc</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:20:06.1200128-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential Excessive Resource Consumption for Audit Logger or MetaData Database</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Does Audit Logger or MetaData Database take explicit steps to control resource consumption? Resource consumption attacks can be hard to deal with, and there are times that it makes sense to let the OS do the job. Be careful that your resource requests don't deadlock, and that they do timeout.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified that excessive write operations could overwhelm the Audit Logger. Mitigation was to apply rate limiting on the internal logging pipeline and use auto-scaling infrastructure so the logger can absorb volume spikes without becoming unavailable. (AWS Well-Architected Framework Security Pillar, aws.amazon.com, 2023) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>3ad70b89-cbaa-46da-90af-60b39866725b</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>a04d8cf3-64f7-4a0f-a673-269ca42890dc</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D2</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S7.1917996b7-6cd4-4ecf-88cd-aa37bea4c160bca30fa8-c269-4f0e-bcdc-c794a6629774331b6ab9-31e3-4c61-afe4-4cb44f086990</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>bca30fa8-c269-4f0e-bcdc-c794a6629774</b:FlowGuid><b:Id>29</b:Id><b:InteractionKey>917996b7-6cd4-4ecf-88cd-aa37bea4c160:bca30fa8-c269-4f0e-bcdc-c794a6629774:331b6ab9-31e3-4c61-afe4-4cb44f086990</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:20:19.5909537-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing of Destination Data Store Credential Database</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Credential Database may be spoofed by an attacker and this may lead to data being written to the attacker's target instead of Credential Database. Consider using a standard authentication mechanism to identify the destination data store.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Recognized the Credential Database is the highest-value target for spoofing because it holds user passwords. Mitigation was to restrict access to the Auth Service only via an internal binary connection, and store all passwords as bcrypt hashes so even database access does not expose plaintext credentials. (OWASP Top 10, owasp.org, 2021) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>917996b7-6cd4-4ecf-88cd-aa37bea4c160</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>331b6ab9-31e3-4c61-afe4-4cb44f086990</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S7.1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T7917996b7-6cd4-4ecf-88cd-aa37bea4c160bca30fa8-c269-4f0e-bcdc-c794a6629774331b6ab9-31e3-4c61-afe4-4cb44f086990</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>bca30fa8-c269-4f0e-bcdc-c794a6629774</b:FlowGuid><b:Id>30</b:Id><b:InteractionKey>917996b7-6cd4-4ecf-88cd-aa37bea4c160:bca30fa8-c269-4f0e-bcdc-c794a6629774:331b6ab9-31e3-4c61-afe4-4cb44f086990</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:20:30.1193256-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential SQL Injection Vulnerability for Credential Database</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Tampering is the act of altering the bits. Tampering with a process involves changing bits in the running process. Similarly, Tampering with a data flow involves changing bits on the wire or between two running processes.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>SQL injection is an attack in which malicious code is inserted into strings that are later passed to an instance of SQL Server for parsing and execution. Any procedure that constructs SQL statements should be reviewed for injection vulnerabilities because SQL Server will execute all syntactically valid queries that it receives. Even parameterized data can be manipulated by a skilled and determined attacker.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Applied parameterized queries and ORM-enforced data access on the Credential Database to prevent SQL injection. Access is limited to the Auth Service only via a least-privilege service account. (NIST SP 800-209, nvlpubs.nist.gov, 2020) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>917996b7-6cd4-4ecf-88cd-aa37bea4c160</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>331b6ab9-31e3-4c61-afe4-4cb44f086990</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T7</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D2917996b7-6cd4-4ecf-88cd-aa37bea4c160bca30fa8-c269-4f0e-bcdc-c794a6629774331b6ab9-31e3-4c61-afe4-4cb44f086990</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>bca30fa8-c269-4f0e-bcdc-c794a6629774</b:FlowGuid><b:Id>31</b:Id><b:InteractionKey>917996b7-6cd4-4ecf-88cd-aa37bea4c160:bca30fa8-c269-4f0e-bcdc-c794a6629774:331b6ab9-31e3-4c61-afe4-4cb44f086990</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:20:54.9530198-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential Excessive Resource Consumption for Auth Service  or Credential Database</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Does Auth Service  or Credential Database take explicit steps to control resource consumption? Resource consumption attacks can be hard to deal with, and there are times that it makes sense to let the OS do the job. Be careful that your resource requests don't deadlock, and that they do timeout.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Found the Auth Service could be targeted by excessive login attempts to exhaust its resources. Mitigation was to implement login rate limiting, account lockout after repeated failures, and CDN/WAF protection at the perimeter to absorb volumetric attacks before they reach the Auth Service. (AWS Well-Architected Framework Security Pillar, aws.amazon.com, 2023) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>917996b7-6cd4-4ecf-88cd-aa37bea4c160</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>331b6ab9-31e3-4c61-afe4-4cb44f086990</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D2</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S7.1290fd120-69d8-46a1-8b55-f5f0b4a8229d97ac13c4-147e-46b0-8603-5bc4a6cc4c79de3f295a-bca5-4e40-a1f6-18648a39555c</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>97ac13c4-147e-46b0-8603-5bc4a6cc4c79</b:FlowGuid><b:Id>32</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:97ac13c4-147e-46b0-8603-5bc4a6cc4c79:de3f295a-bca5-4e40-a1f6-18648a39555c</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:21:11.7404793-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing of Destination Data Store KMS / Key Vault</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>KMS / Key Vault may be spoofed by an attacker and this may lead to data being written to the attacker's target instead of KMS / Key Vault. Consider using a standard authentication mechanism to identify the destination data store.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified that the KMS/Key Vault could be spoofed by a malicious service pretending to be an authorized caller. Mitigation was to enforce mutual authentication on all KMS connections and restrict access to explicitly whitelisted internal services only via least-privilege IAM policies. (OWASP Top 10, owasp.org, 2021) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary biriectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>de3f295a-bca5-4e40-a1f6-18648a39555c</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S7.1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T7290fd120-69d8-46a1-8b55-f5f0b4a8229d97ac13c4-147e-46b0-8603-5bc4a6cc4c79de3f295a-bca5-4e40-a1f6-18648a39555c</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>97ac13c4-147e-46b0-8603-5bc4a6cc4c79</b:FlowGuid><b:Id>33</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:97ac13c4-147e-46b0-8603-5bc4a6cc4c79:de3f295a-bca5-4e40-a1f6-18648a39555c</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:21:32.109958-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential SQL Injection Vulnerability for KMS / Key Vault</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Tampering is the act of altering the bits. Tampering with a process involves changing bits in the running process. Similarly, Tampering with a data flow involves changing bits on the wire or between two running processes.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>SQL injection is an attack in which malicious code is inserted into strings that are later passed to an instance of SQL Server for parsing and execution. Any procedure that constructs SQL statements should be reviewed for injection vulnerabilities because SQL Server will execute all syntactically valid queries that it receives. Even parameterized data can be manipulated by a skilled and determined attacker.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Applied parameterized queries and strict input validation on all KMS/Key Vault operations. Encryption key metadata must not be modifiable by any service other than the designated key management process. (NIST SP 800-209, nvlpubs.nist.gov, 2020) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary biriectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>de3f295a-bca5-4e40-a1f6-18648a39555c</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T7</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D2290fd120-69d8-46a1-8b55-f5f0b4a8229d97ac13c4-147e-46b0-8603-5bc4a6cc4c79de3f295a-bca5-4e40-a1f6-18648a39555c</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>97ac13c4-147e-46b0-8603-5bc4a6cc4c79</b:FlowGuid><b:Id>34</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:97ac13c4-147e-46b0-8603-5bc4a6cc4c79:de3f295a-bca5-4e40-a1f6-18648a39555c</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:21:45.8091789-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential Excessive Resource Consumption for File Upload/Download API or KMS / Key Vault</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Does File Upload/Download API or KMS / Key Vault take explicit steps to control resource consumption? Resource consumption attacks can be hard to deal with, and there are times that it makes sense to let the OS do the job. Be careful that your resource requests don't deadlock, and that they do timeout.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Recognized that flooding the File Upload API could exhaust processing resources. Mitigation was the 100MB file size limit, API Gateway throttling at 100 req/min/user, and Cloudflare/AWS Shield DDoS protection at the edge layer. (AWS Well-Architected Framework Security Pillar, aws.amazon.com, 2023) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary biriectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>de3f295a-bca5-4e40-a1f6-18648a39555c</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D2</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>R62fee6239-2740-4c3e-bb93-9984dd99fc7e9d897276-80f7-4a63-8a7b-0af44e2ff0c5852b9584-943b-4a59-84e6-a3ebd7414d35</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>9d897276-80f7-4a63-8a7b-0af44e2ff0c5</b:FlowGuid><b:Id>35</b:Id><b:InteractionKey>2fee6239-2740-4c3e-bb93-9984dd99fc7e:9d897276-80f7-4a63-8a7b-0af44e2ff0c5:852b9584-943b-4a59-84e6-a3ebd7414d35</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:22:00.5057196-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential Data Repudiation by CDN / WAF</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Repudiation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Repudiation threats involve an adversary denying that something happened.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Content Delivery Network/ web Appl Firewall claims that it did not receive data from a source outside the trust boundary. Consider using logging or auditing to record the source, time, and summary of the received data.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Determined that the Content Delivery Network layer must also have its activity logged so there is a complete audit trail from the user all the way to the backend. Implemented immutable write-once logging with HMAC signing so no one can deny what was delivered through the CDN. (OWASP Threat Modeling Process, owasp.org, 2024) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectiona</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>2fee6239-2740-4c3e-bb93-9984dd99fc7e</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>852b9584-943b-4a59-84e6-a3ebd7414d35</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>R6</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D32fee6239-2740-4c3e-bb93-9984dd99fc7e9d897276-80f7-4a63-8a7b-0af44e2ff0c5852b9584-943b-4a59-84e6-a3ebd7414d35</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>9d897276-80f7-4a63-8a7b-0af44e2ff0c5</b:FlowGuid><b:Id>36</b:Id><b:InteractionKey>2fee6239-2740-4c3e-bb93-9984dd99fc7e:9d897276-80f7-4a63-8a7b-0af44e2ff0c5:852b9584-943b-4a59-84e6-a3ebd7414d35</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:22:18.3371056-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential Process Crash or Stop for CDN / WAF</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Content Delivery Network/ web Appl Firewall crashes, halts, stops or runs slowly; in all cases violating an availability metric.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified the CDN layer as a target for process flooding. Mitigation was to use Cloudflare or AWS Shield at the CDN/WAF layer specifically to absorb HTTP flood attacks and slow-rate attacks before they reach the API Gateway. (AWS Well-Architected Framework Security Pillar, aws.amazon.com, 2023) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectiona</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>2fee6239-2740-4c3e-bb93-9984dd99fc7e</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>852b9584-943b-4a59-84e6-a3ebd7414d35</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D3</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D42fee6239-2740-4c3e-bb93-9984dd99fc7e9d897276-80f7-4a63-8a7b-0af44e2ff0c5852b9584-943b-4a59-84e6-a3ebd7414d35</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>9d897276-80f7-4a63-8a7b-0af44e2ff0c5</b:FlowGuid><b:Id>37</b:Id><b:InteractionKey>2fee6239-2740-4c3e-bb93-9984dd99fc7e:9d897276-80f7-4a63-8a7b-0af44e2ff0c5:852b9584-943b-4a59-84e6-a3ebd7414d35</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:22:31.2755761-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Flow HTTPS Is Potentially Interrupted</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An external agent interrupts data flowing across a trust boundary in either direction.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Found that external agents could attempt to exhaust HTTPS connection resources at the CDN/WAF. Mitigation included connection rate limiting at the CDN layer and WAF rules targeting known DDoS patterns such as SYN floods and slow HTTP attacks. (AWS Well-Architected Framework Security Pillar, aws.amazon.com, 2023) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectiona</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>2fee6239-2740-4c3e-bb93-9984dd99fc7e</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>852b9584-943b-4a59-84e6-a3ebd7414d35</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D4</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E62fee6239-2740-4c3e-bb93-9984dd99fc7e9d897276-80f7-4a63-8a7b-0af44e2ff0c5852b9584-943b-4a59-84e6-a3ebd7414d35</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>9d897276-80f7-4a63-8a7b-0af44e2ff0c5</b:FlowGuid><b:Id>38</b:Id><b:InteractionKey>2fee6239-2740-4c3e-bb93-9984dd99fc7e:9d897276-80f7-4a63-8a7b-0af44e2ff0c5:852b9584-943b-4a59-84e6-a3ebd7414d35</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:22:50.0583434-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>CDN / WAF May be Subject to Elevation of Privilege Using Remote Code Execution</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Browser may be able to remotely execute code for Content Delivery Network/ web Appl Firewall.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified that a browser-based attacker could attempt to exploit CDN/WAF misconfigurations to gain elevated access. Mitigation was to enforce strict WAF rule sets, disable directory listing, and ensure the CDN only serves pre-authorized content paths. (Microsoft STRIDE Threat Modeling Framework, learn.microsoft.com, 2022) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectiona</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>2fee6239-2740-4c3e-bb93-9984dd99fc7e</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>852b9584-943b-4a59-84e6-a3ebd7414d35</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E6</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E72fee6239-2740-4c3e-bb93-9984dd99fc7e9d897276-80f7-4a63-8a7b-0af44e2ff0c5852b9584-943b-4a59-84e6-a3ebd7414d35</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>9d897276-80f7-4a63-8a7b-0af44e2ff0c5</b:FlowGuid><b:Id>39</b:Id><b:InteractionKey>2fee6239-2740-4c3e-bb93-9984dd99fc7e:9d897276-80f7-4a63-8a7b-0af44e2ff0c5:852b9584-943b-4a59-84e6-a3ebd7414d35</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:23:14.3415908-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Elevation by Changing the Execution Flow in CDN / WAF</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An attacker may pass data into Content Delivery Network/ web Appl Firewall in order to change the flow of program execution within Content Delivery Network/ web Appl Firewall to the attacker's choosing.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Found that an attacker exploiting the CDN layer could potentially bypass the API Gateway. Mitigation was to enforce that all backend services reject any request not originating from the API Gateway, and to apply mutual TLS between the CDN and the API Gateway. (Microsoft STRIDE Threat Modeling Framework, learn.microsoft.com, 2022) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectiona</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>2fee6239-2740-4c3e-bb93-9984dd99fc7e</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>852b9584-943b-4a59-84e6-a3ebd7414d35</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E7</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>8404dcf5-bdd8-4902-abc2-3b6c967b02612fee6239-2740-4c3e-bb93-9984dd99fc7e9d897276-80f7-4a63-8a7b-0af44e2ff0c5852b9584-943b-4a59-84e6-a3ebd7414d35</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>9d897276-80f7-4a63-8a7b-0af44e2ff0c5</b:FlowGuid><b:Id>40</b:Id><b:InteractionKey>2fee6239-2740-4c3e-bb93-9984dd99fc7e:9d897276-80f7-4a63-8a7b-0af44e2ff0c5:852b9584-943b-4a59-84e6-a3ebd7414d35</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:23:28.6179805-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Cross Site Request Forgery</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Cross-site request forgery (CSRF or XSRF) is a type of attack in which an attacker forces a user's browser to make a forged request to a vulnerable site by exploiting an existing trust relationship between the browser and the vulnerable web site.  In a simple scenario, a user is logged in to web site A using a cookie as a credential.  The other browses to web site B.  Web site B returns a page with a hidden form that posts to web site A.  Since the browser will carry the user's cookie to web site A, web site B now can take any action on web site A, for example, adding an admin to an account.  The attack can be used to exploit any requests that the browser automatically authenticates, e.g. by session cookie, integrated authentication, IP whitelisting, …  The attack can be carried out in many ways such as by luring the victim to a site under control of the attacker, getting the user to click a link in a phishing email, or hacking a reputable web site that the victim will visit. The issue can only be resolved on the server side by requiring that all authenticated state-changing requests include an additional piece of secret payload (canary or CSRF token) which is known only to the legitimate web site and the browser and which is protected in transit through SSL/TLS. See the Forgery Protection property on the flow stencil for a list of mitigations.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Studied that Cross-Site Request Forgery allows attackers to trick authenticated users into making unauthorized requests. Mitigation was to implement anti-CSRF tokens on all state-changing API requests and enforce the SameSite cookie attribute to block cross-origin request forgery. (OWASP Top 10, owasp.org, 2021) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectiona</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>2fee6239-2740-4c3e-bb93-9984dd99fc7e</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>852b9584-943b-4a59-84e6-a3ebd7414d35</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>8404dcf5-bdd8-4902-abc2-3b6c967b0261</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>R6983264e1-020a-4a51-841b-f848f8b2e5d64f2fb21a-dca5-49d6-b1e1-dca73f7fdc535ff87fa8-86d3-4a55-9f50-262e41fa71fc</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>4f2fb21a-dca5-49d6-b1e1-dca73f7fdc53</b:FlowGuid><b:Id>41</b:Id><b:InteractionKey>983264e1-020a-4a51-841b-f848f8b2e5d6:4f2fb21a-dca5-49d6-b1e1-dca73f7fdc53:5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:23:44.7602465-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential Data Repudiation by API Gateway</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Repudiation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Repudiation threats involve an adversary denying that something happened.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>API Gateway claims that it did not receive data from a source outside the trust boundary. Consider using logging or auditing to record the source, time, and summary of the received data.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Determined that API Gateway activity must be fully logged so no request can be denied after the fact. Implemented write-once immutable audit logging with timestamps, user ID, source IP, and request details for every API Gateway transaction. (OWASP Threat Modeling Process, owasp.org, 2024) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>983264e1-020a-4a51-841b-f848f8b2e5d6</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>R6</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D3983264e1-020a-4a51-841b-f848f8b2e5d64f2fb21a-dca5-49d6-b1e1-dca73f7fdc535ff87fa8-86d3-4a55-9f50-262e41fa71fc</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>4f2fb21a-dca5-49d6-b1e1-dca73f7fdc53</b:FlowGuid><b:Id>42</b:Id><b:InteractionKey>983264e1-020a-4a51-841b-f848f8b2e5d6:4f2fb21a-dca5-49d6-b1e1-dca73f7fdc53:5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:23:58.1191499-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential Process Crash or Stop for API Gateway</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>API Gateway crashes, halts, stops or runs slowly; in all cases violating an availability metric.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified that the API Gateway is the single entry point for all traffic making it a prime DoS target. Mitigation was rate limiting at 100 req/min/user, AWS Shield/Cloudflare DDoS protection, and auto-scaling the gateway to absorb traffic spikes. (AWS Well-Architected Framework Security Pillar, aws.amazon.com, 2023) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>983264e1-020a-4a51-841b-f848f8b2e5d6</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D3</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D4983264e1-020a-4a51-841b-f848f8b2e5d64f2fb21a-dca5-49d6-b1e1-dca73f7fdc535ff87fa8-86d3-4a55-9f50-262e41fa71fc</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>4f2fb21a-dca5-49d6-b1e1-dca73f7fdc53</b:FlowGuid><b:Id>43</b:Id><b:InteractionKey>983264e1-020a-4a51-841b-f848f8b2e5d6:4f2fb21a-dca5-49d6-b1e1-dca73f7fdc53:5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:24:13.8621589-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Flow HTTPS Is Potentially Interrupted</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An external agent interrupts data flowing across a trust boundary in either direction.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Found that external agents could flood the HTTPS connection pool of the API Gateway. Mitigation included connection rate limiting, WAF rules blocking known DDoS patterns, and CDN-layer absorption of volumetric attacks before they reach the gateway. (AWS Well-Architected Framework Security Pillar, aws.amazon.com, 2023) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>983264e1-020a-4a51-841b-f848f8b2e5d6</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D4</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E6983264e1-020a-4a51-841b-f848f8b2e5d64f2fb21a-dca5-49d6-b1e1-dca73f7fdc535ff87fa8-86d3-4a55-9f50-262e41fa71fc</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>4f2fb21a-dca5-49d6-b1e1-dca73f7fdc53</b:FlowGuid><b:Id>44</b:Id><b:InteractionKey>983264e1-020a-4a51-841b-f848f8b2e5d6:4f2fb21a-dca5-49d6-b1e1-dca73f7fdc53:5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:24:33.4558064-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>API Gateway May be Subject to Elevation of Privilege Using Remote Code Execution</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Mobile App may be able to remotely execute code for API Gateway.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified that a Mobile App user could attempt to escalate privileges through the API Gateway. Mitigation was server-side RBAC enforcement at every API route with no trust placed in client-supplied role claims. (Microsoft STRIDE Threat Modeling Framework, learn.microsoft.com, 2022) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>983264e1-020a-4a51-841b-f848f8b2e5d6</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E6</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E7983264e1-020a-4a51-841b-f848f8b2e5d64f2fb21a-dca5-49d6-b1e1-dca73f7fdc535ff87fa8-86d3-4a55-9f50-262e41fa71fc</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>4f2fb21a-dca5-49d6-b1e1-dca73f7fdc53</b:FlowGuid><b:Id>45</b:Id><b:InteractionKey>983264e1-020a-4a51-841b-f848f8b2e5d6:4f2fb21a-dca5-49d6-b1e1-dca73f7fdc53:5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:24:46.2739458-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Elevation by Changing the Execution Flow in API Gateway</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An attacker may pass data into API Gateway in order to change the flow of program execution within API Gateway to the attacker's choosing.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Recognized that an attacker gaining a foothold in any component could try to escalate to higher privileges. Mitigation was the principle of least privilege applied to all service accounts and user roles, with privilege changes requiring separate signed admin tokens. (OWASP Top 10, owasp.org, 2021) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>983264e1-020a-4a51-841b-f848f8b2e5d6</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E7</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>8404dcf5-bdd8-4902-abc2-3b6c967b0261983264e1-020a-4a51-841b-f848f8b2e5d64f2fb21a-dca5-49d6-b1e1-dca73f7fdc535ff87fa8-86d3-4a55-9f50-262e41fa71fc</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>4f2fb21a-dca5-49d6-b1e1-dca73f7fdc53</b:FlowGuid><b:Id>46</b:Id><b:InteractionKey>983264e1-020a-4a51-841b-f848f8b2e5d6:4f2fb21a-dca5-49d6-b1e1-dca73f7fdc53:5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:24:58.9386055-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Cross Site Request Forgery</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Cross-site request forgery (CSRF or XSRF) is a type of attack in which an attacker forces a user's browser to make a forged request to a vulnerable site by exploiting an existing trust relationship between the browser and the vulnerable web site.  In a simple scenario, a user is logged in to web site A using a cookie as a credential.  The other browses to web site B.  Web site B returns a page with a hidden form that posts to web site A.  Since the browser will carry the user's cookie to web site A, web site B now can take any action on web site A, for example, adding an admin to an account.  The attack can be used to exploit any requests that the browser automatically authenticates, e.g. by session cookie, integrated authentication, IP whitelisting, …  The attack can be carried out in many ways such as by luring the victim to a site under control of the attacker, getting the user to click a link in a phishing email, or hacking a reputable web site that the victim will visit. The issue can only be resolved on the server side by requiring that all authenticated state-changing requests include an additional piece of secret payload (canary or CSRF token) which is known only to the legitimate web site and the browser and which is protected in transit through SSL/TLS. See the Forgery Protection property on the flow stencil for a list of mitigations.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Applied anti-CSRF token enforcement and SameSite cookie policy as mitigations for Cross-Site Request Forgery-based privilege escalation. All state-changing operations require a valid server-issued CSRF token that cannot be forged cross-origin. (OWASP Top 10, owasp.org, 2021) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>983264e1-020a-4a51-841b-f848f8b2e5d6</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>8404dcf5-bdd8-4902-abc2-3b6c967b0261</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S8917996b7-6cd4-4ecf-88cd-aa37bea4c160a5c259b6-a28d-4391-bccd-7d358148f043bf23a18b-7057-44eb-b3a8-80b8d3bc9a18</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>a5c259b6-a28d-4391-bccd-7d358148f043</b:FlowGuid><b:Id>47</b:Id><b:InteractionKey>917996b7-6cd4-4ecf-88cd-aa37bea4c160:a5c259b6-a28d-4391-bccd-7d358148f043:bf23a18b-7057-44eb-b3a8-80b8d3bc9a18</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:25:12.8352542-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing of the Authorization Provider External Destination Entity</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Authorization Provider may be spoofed by an attacker and this may lead to data being sent to the attacker's target instead of Authorization Provider. Consider using a standard authentication mechanism to identify the external entity.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified that the Authorization Provider connection could be spoofed by a fake OAuth endpoint. Mitigation was to validate the Authorization Provider's identity using certificate pinning and only accept redirect URIs that are pre-registered in the OAuth application configuration. (OWASP Threat Modeling Process, owasp.org, 2024) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>917996b7-6cd4-4ecf-88cd-aa37bea4c160</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>bf23a18b-7057-44eb-b3a8-80b8d3bc9a18</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S8</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>R7917996b7-6cd4-4ecf-88cd-aa37bea4c160a5c259b6-a28d-4391-bccd-7d358148f043bf23a18b-7057-44eb-b3a8-80b8d3bc9a18</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>a5c259b6-a28d-4391-bccd-7d358148f043</b:FlowGuid><b:Id>48</b:Id><b:InteractionKey>917996b7-6cd4-4ecf-88cd-aa37bea4c160:a5c259b6-a28d-4391-bccd-7d358148f043:bf23a18b-7057-44eb-b3a8-80b8d3bc9a18</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:25:30.4858637-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>External Entity Authorization Provider Potentially Denies Receiving Data</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Repudiation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Repudiation threats involve an adversary denying that something happened.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Authorization Provider claims that it did not receive data from a process on the other side of the trust boundary. Consider using logging or auditing to record the source, time, and summary of the received data.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Found that external entity interactions with the Authorization Provider must be logged to prevent denial of authentication events. Ensured all OAuth token exchanges are captured in the audit log with timestamps and correlation IDs. (OWASP Threat Modeling Process, owasp.org, 2024) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>917996b7-6cd4-4ecf-88cd-aa37bea4c160</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>bf23a18b-7057-44eb-b3a8-80b8d3bc9a18</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>R7</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D4917996b7-6cd4-4ecf-88cd-aa37bea4c160a5c259b6-a28d-4391-bccd-7d358148f043bf23a18b-7057-44eb-b3a8-80b8d3bc9a18</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>RICHARDA08F\Richard</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>a5c259b6-a28d-4391-bccd-7d358148f043</b:FlowGuid><b:Id>49</b:Id><b:InteractionKey>917996b7-6cd4-4ecf-88cd-aa37bea4c160:a5c259b6-a28d-4391-bccd-7d358148f043:bf23a18b-7057-44eb-b3a8-80b8d3bc9a18</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-15T20:25:46.1985567-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Flow HTTPS Is Potentially Interrupted</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An external agent interrupts data flowing across a trust boundary in either direction.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Recognized that external agents could flood the HTTPS endpoint connecting to the Authorization Provider. Mitigation was CDN/WAF rate limiting at the perimeter and OAuth provider-level rate limiting on authentication attempts. (AWS Well-Architected Framework Security Pillar, aws.amazon.com, 2023) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>917996b7-6cd4-4ecf-88cd-aa37bea4c160</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>bf23a18b-7057-44eb-b3a8-80b8d3bc9a18</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D4</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S1917996b7-6cd4-4ecf-88cd-aa37bea4c160bca30fa8-c269-4f0e-bcdc-c794a6629774331b6ab9-31e3-4c61-afe4-4cb44f086990</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>bca30fa8-c269-4f0e-bcdc-c794a6629774</b:FlowGuid><b:Id>50</b:Id><b:InteractionKey>917996b7-6cd4-4ecf-88cd-aa37bea4c160:bca30fa8-c269-4f0e-bcdc-c794a6629774:331b6ab9-31e3-4c61-afe4-4cb44f086990</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:45:59.6721526-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing the Auth Service  Process</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Auth Service  may be spoofed by an attacker and this may lead to unauthorized access to Credential Database. Consider using a standard authentication mechanism to identify the source process.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified that the Auth Service could be spoofed if its identity is not properly verified by calling services. My mitigation was mutual TLS authentication between the Auth Service and all services that call it, so only verified internal services can interact with it. (OWASP Threat Modeling Process, owasp.org, 2024) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>917996b7-6cd4-4ecf-88cd-aa37bea4c160</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>331b6ab9-31e3-4c61-afe4-4cb44f086990</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T18917996b7-6cd4-4ecf-88cd-aa37bea4c160bca30fa8-c269-4f0e-bcdc-c794a6629774331b6ab9-31e3-4c61-afe4-4cb44f086990</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>bca30fa8-c269-4f0e-bcdc-c794a6629774</b:FlowGuid><b:Id>51</b:Id><b:InteractionKey>917996b7-6cd4-4ecf-88cd-aa37bea4c160:bca30fa8-c269-4f0e-bcdc-c794a6629774:331b6ab9-31e3-4c61-afe4-4cb44f086990</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:50:08.6734056-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>The Credential Database Data Store Could Be Corrupted</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Tampering is the act of altering the bits. Tampering with a process involves changing bits in the running process. Similarly, Tampering with a data flow involves changing bits on the wire or between two running processes.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Data flowing across Binary bidirectional may be tampered with by an attacker. This may lead to corruption of Credential Database. Ensure the integrity of the data flow to the data store.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Determined that credential data flowing to and from the Credential Database could be tampered with. My mitigation was TLS encryption on all internal binary connections and bcrypt hashing of all passwords so even intercepted data is unusable. (NIST SP 800-209, nvlpubs.nist.gov, 2020)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>917996b7-6cd4-4ecf-88cd-aa37bea4c160</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>331b6ab9-31e3-4c61-afe4-4cb44f086990</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T18</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>R8917996b7-6cd4-4ecf-88cd-aa37bea4c160bca30fa8-c269-4f0e-bcdc-c794a6629774331b6ab9-31e3-4c61-afe4-4cb44f086990</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>bca30fa8-c269-4f0e-bcdc-c794a6629774</b:FlowGuid><b:Id>52</b:Id><b:InteractionKey>917996b7-6cd4-4ecf-88cd-aa37bea4c160:bca30fa8-c269-4f0e-bcdc-c794a6629774:331b6ab9-31e3-4c61-afe4-4cb44f086990</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:50:25.338211-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Store Denies Credential Database Potentially Writing Data</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Repudiation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Repudiation threats involve an adversary denying that something happened.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Credential Database claims that it did not write data received from an entity on the other side of the trust boundary. Consider using logging or auditing to record the source, time, and summary of the received data.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Found that Credential Database access events must be logged to prevent denial of unauthorized access attempts. I implemented audit logging of all authentication events including failed login attempts with timestamps and source IP addresses. (OWASP Threat Modeling Process, owasp.org, 2024)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>917996b7-6cd4-4ecf-88cd-aa37bea4c160</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>331b6ab9-31e3-4c61-afe4-4cb44f086990</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>R8</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>I6917996b7-6cd4-4ecf-88cd-aa37bea4c160bca30fa8-c269-4f0e-bcdc-c794a6629774331b6ab9-31e3-4c61-afe4-4cb44f086990</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>bca30fa8-c269-4f0e-bcdc-c794a6629774</b:FlowGuid><b:Id>53</b:Id><b:InteractionKey>917996b7-6cd4-4ecf-88cd-aa37bea4c160:bca30fa8-c269-4f0e-bcdc-c794a6629774:331b6ab9-31e3-4c61-afe4-4cb44f086990</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:50:43.7538772-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Flow Sniffing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Information Disclosure</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Information disclosure happens when the information can be read by an unauthorized party.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Data flowing across Binary bidirectional may be sniffed by an attacker. Depending on what type of data an attacker can read, it may be used to attack other parts of the system or simply be a disclosure of information leading to compliance violations. Consider encrypting the data flow.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified that credential data could be intercepted on the binary connection between Auth Service and Credential Database. My mitigation was encryption of the internal connection and bcrypt hashing of all stored passwords so intercepted data reveals nothing useful. (OWASP Top 10, owasp.org, 2021)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>917996b7-6cd4-4ecf-88cd-aa37bea4c160</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>331b6ab9-31e3-4c61-afe4-4cb44f086990</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>I6</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D4917996b7-6cd4-4ecf-88cd-aa37bea4c160bca30fa8-c269-4f0e-bcdc-c794a6629774331b6ab9-31e3-4c61-afe4-4cb44f086990</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>bca30fa8-c269-4f0e-bcdc-c794a6629774</b:FlowGuid><b:Id>54</b:Id><b:InteractionKey>917996b7-6cd4-4ecf-88cd-aa37bea4c160:bca30fa8-c269-4f0e-bcdc-c794a6629774:331b6ab9-31e3-4c61-afe4-4cb44f086990</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:51:03.8569422-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Flow Binary Is Potentially Interrupted</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An external agent interrupts data flowing across a trust boundary in either direction.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Found that the binary data flow to the Credential Database could be flooded. My mitigation was connection rate limiting, login attempt throttling with account lockout after repeated failures, and infrastructure auto-scaling to handle legitimate traffic spikes. (AWS Well-Architected Framework Security Pillar, aws.amazon.com, 2023)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>917996b7-6cd4-4ecf-88cd-aa37bea4c160</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>331b6ab9-31e3-4c61-afe4-4cb44f086990</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D4</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D5917996b7-6cd4-4ecf-88cd-aa37bea4c160bca30fa8-c269-4f0e-bcdc-c794a6629774331b6ab9-31e3-4c61-afe4-4cb44f086990</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>bca30fa8-c269-4f0e-bcdc-c794a6629774</b:FlowGuid><b:Id>55</b:Id><b:InteractionKey>917996b7-6cd4-4ecf-88cd-aa37bea4c160:bca30fa8-c269-4f0e-bcdc-c794a6629774:331b6ab9-31e3-4c61-afe4-4cb44f086990</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:51:45.520984-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Store Inaccessible</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An external agent prevents access to a data store on the other side of the trust boundary.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Applied the same rate limiting and auto-scaling controls to the Credential Database data store as threat 54, ensuring that storage-level denial of service attempts are absorbed before causing system unavailability. (AWS Well-Architected Framework Security Pillar, aws.amazon.com, 2023)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>917996b7-6cd4-4ecf-88cd-aa37bea4c160</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>331b6ab9-31e3-4c61-afe4-4cb44f086990</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D5</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S1290fd120-69d8-46a1-8b55-f5f0b4a8229d8f075b78-4e76-4f94-a4ae-7805b5195bd539c51d12-c6ef-4824-9e7d-6baec5737118</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>8f075b78-4e76-4f94-a4ae-7805b5195bd5</b:FlowGuid><b:Id>83</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:8f075b78-4e76-4f94-a4ae-7805b5195bd5:39c51d12-c6ef-4824-9e7d-6baec5737118</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:52:08.0968464-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing the File Upload/Download API Process</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>File Upload/Download API may be spoofed by an attacker and this may lead to unauthorized access to Cloud Storage. Consider using a standard authentication mechanism to identify the source process.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified that the File Upload/Download API could be accessed by a spoofed service or user. My mitigation was pre-signed URL generation tied to verified user identity and short expiry windows so stolen URLs cannot be reused. (OWASP Top 10, owasp.org, 2021)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary biriectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>39c51d12-c6ef-4824-9e7d-6baec5737118</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T18290fd120-69d8-46a1-8b55-f5f0b4a8229d8f075b78-4e76-4f94-a4ae-7805b5195bd539c51d12-c6ef-4824-9e7d-6baec5737118</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>8f075b78-4e76-4f94-a4ae-7805b5195bd5</b:FlowGuid><b:Id>84</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:8f075b78-4e76-4f94-a4ae-7805b5195bd5:39c51d12-c6ef-4824-9e7d-6baec5737118</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:52:26.5051806-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>The Cloud Storage Data Store Could Be Corrupted</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Tampering is the act of altering the bits. Tampering with a process involves changing bits in the running process. Similarly, Tampering with a data flow involves changing bits on the wire or between two running processes.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Data flowing across Binary biriectional may be tampered with by an attacker. This may lead to corruption of Cloud Storage. Ensure the integrity of the data flow to the data store.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Found that Cloud Storage data could be tampered with if the connection between the File API and Cloud Storage is not protected. My mitigation was AES-256 encryption at rest, SHA-256 integrity verification, and TLS on all connections to the cloud storage provider. (NIST SP 800-209, nvlpubs.nist.gov, 2020)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary biriectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>39c51d12-c6ef-4824-9e7d-6baec5737118</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T18</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>R8290fd120-69d8-46a1-8b55-f5f0b4a8229d8f075b78-4e76-4f94-a4ae-7805b5195bd539c51d12-c6ef-4824-9e7d-6baec5737118</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>8f075b78-4e76-4f94-a4ae-7805b5195bd5</b:FlowGuid><b:Id>85</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:8f075b78-4e76-4f94-a4ae-7805b5195bd5:39c51d12-c6ef-4824-9e7d-6baec5737118</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:52:46.1291476-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Store Denies Cloud Storage Potentially Writing Data</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Repudiation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Repudiation threats involve an adversary denying that something happened.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Cloud Storage claims that it did not write data received from an entity on the other side of the trust boundary. Consider using logging or auditing to record the source, time, and summary of the received data.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Determined that all Cloud Storage access events must be captured in the audit log so no upload, download, or delete can be denied. I implemented write-once immutable logging via CloudTrail/Azure Monitor with HMAC signing for all storage operations. (OWASP Threat Modeling Process, owasp.org, 2024)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary biriectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>39c51d12-c6ef-4824-9e7d-6baec5737118</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>R8</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>I6290fd120-69d8-46a1-8b55-f5f0b4a8229d8f075b78-4e76-4f94-a4ae-7805b5195bd539c51d12-c6ef-4824-9e7d-6baec5737118</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>8f075b78-4e76-4f94-a4ae-7805b5195bd5</b:FlowGuid><b:Id>86</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:8f075b78-4e76-4f94-a4ae-7805b5195bd5:39c51d12-c6ef-4824-9e7d-6baec5737118</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:53:04.6268988-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Flow Sniffing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Information Disclosure</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Information disclosure happens when the information can be read by an unauthorized party.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Data flowing across Binary biriectional may be sniffed by an attacker. Depending on what type of data an attacker can read, it may be used to attack other parts of the system or simply be a disclosure of information leading to compliance violations. Consider encrypting the data flow.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified that data flowing between the File API and Cloud Storage could be intercepted. My mitigation was AES-256 encryption at rest and TLS 1.2+ in transit so intercepted data is unreadable without the KMS-managed encryption keys. (OWASP Top 10, owasp.org, 2021)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary biriectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>39c51d12-c6ef-4824-9e7d-6baec5737118</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>I6</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D4290fd120-69d8-46a1-8b55-f5f0b4a8229d8f075b78-4e76-4f94-a4ae-7805b5195bd539c51d12-c6ef-4824-9e7d-6baec5737118</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>8f075b78-4e76-4f94-a4ae-7805b5195bd5</b:FlowGuid><b:Id>87</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:8f075b78-4e76-4f94-a4ae-7805b5195bd5:39c51d12-c6ef-4824-9e7d-6baec5737118</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:53:20.3376268-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Flow Binary Is Potentially Interrupted</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An external agent interrupts data flowing across a trust boundary in either direction.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Applied the same upload flood mitigations — 100MB file size limit, rate limiting, and AWS Shield/Cloudflare — to protect the binary data flow between File API and Cloud Storage from denial of service attempts. (AWS Well-Architected Framework Security Pillar, aws.amazon.com, 2023)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary biriectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>39c51d12-c6ef-4824-9e7d-6baec5737118</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D4</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D5290fd120-69d8-46a1-8b55-f5f0b4a8229d8f075b78-4e76-4f94-a4ae-7805b5195bd539c51d12-c6ef-4824-9e7d-6baec5737118</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>8f075b78-4e76-4f94-a4ae-7805b5195bd5</b:FlowGuid><b:Id>88</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:8f075b78-4e76-4f94-a4ae-7805b5195bd5:39c51d12-c6ef-4824-9e7d-6baec5737118</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:53:38.7460406-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Store Inaccessible</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An external agent prevents access to a data store on the other side of the trust boundary.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Found that the Cloud Storage data store itself could be overwhelmed. My mitigation was multi-region replication for availability, storage quota enforcement per user, and CDN/WAF protection absorbing volumetric attacks at the perimeter. (AWS Well-Architected Framework Security Pillar, aws.amazon.com, 2023) </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary biriectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>39c51d12-c6ef-4824-9e7d-6baec5737118</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D5</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S1290fd120-69d8-46a1-8b55-f5f0b4a8229d97ac13c4-147e-46b0-8603-5bc4a6cc4c79de3f295a-bca5-4e40-a1f6-18648a39555c</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>97ac13c4-147e-46b0-8603-5bc4a6cc4c79</b:FlowGuid><b:Id>89</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:97ac13c4-147e-46b0-8603-5bc4a6cc4c79:de3f295a-bca5-4e40-a1f6-18648a39555c</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:53:57.9047508-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing the File Upload/Download API Process</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>File Upload/Download API may be spoofed by an attacker and this may lead to unauthorized access to KMS / Key Vault. Consider using a standard authentication mechanism to identify the source process.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified a second spoofing risk on the File Upload/Download API from the KMS connection direction. My mitigation was mutual authentication between File API and KMS using IAM-based service identity so only the authorized File API can request encryption keys. (OWASP Top 10, owasp.org, 2021)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary biriectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>de3f295a-bca5-4e40-a1f6-18648a39555c</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T18290fd120-69d8-46a1-8b55-f5f0b4a8229d97ac13c4-147e-46b0-8603-5bc4a6cc4c79de3f295a-bca5-4e40-a1f6-18648a39555c</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>97ac13c4-147e-46b0-8603-5bc4a6cc4c79</b:FlowGuid><b:Id>90</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:97ac13c4-147e-46b0-8603-5bc4a6cc4c79:de3f295a-bca5-4e40-a1f6-18648a39555c</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:54:14.3451254-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>The KMS / Key Vault Data Store Could Be Corrupted</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Tampering is the act of altering the bits. Tampering with a process involves changing bits in the running process. Similarly, Tampering with a data flow involves changing bits on the wire or between two running processes.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Data flowing across Binary biriectional may be tampered with by an attacker. This may lead to corruption of KMS / Key Vault. Ensure the integrity of the data flow to the data store.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Found that KMS key data could be tampered with if the binary connection between File API and KMS is unprotected. My mitigation was encrypted internal connections and strict IAM policies limiting which services can read or modify key metadata. (NIST SP 800-209, nvlpubs.nist.gov, 2020)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary biriectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>de3f295a-bca5-4e40-a1f6-18648a39555c</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T18</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>R8290fd120-69d8-46a1-8b55-f5f0b4a8229d97ac13c4-147e-46b0-8603-5bc4a6cc4c79de3f295a-bca5-4e40-a1f6-18648a39555c</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>97ac13c4-147e-46b0-8603-5bc4a6cc4c79</b:FlowGuid><b:Id>91</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:97ac13c4-147e-46b0-8603-5bc4a6cc4c79:de3f295a-bca5-4e40-a1f6-18648a39555c</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:54:35.3212641-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Store Denies KMS / Key Vault Potentially Writing Data</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Repudiation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Repudiation threats involve an adversary denying that something happened.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>KMS / Key Vault claims that it did not write data received from an entity on the other side of the trust boundary. Consider using logging or auditing to record the source, time, and summary of the received data.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Determined that all KMS key access events must be logged to prove which service requested which key and when. I implemented CloudTrail/Azure Monitor logging of all key management operations with HMAC-signed tamper-evident records. (OWASP Threat Modeling Process, owasp.org, 2024)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary biriectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>de3f295a-bca5-4e40-a1f6-18648a39555c</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>R8</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>I6290fd120-69d8-46a1-8b55-f5f0b4a8229d97ac13c4-147e-46b0-8603-5bc4a6cc4c79de3f295a-bca5-4e40-a1f6-18648a39555c</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>97ac13c4-147e-46b0-8603-5bc4a6cc4c79</b:FlowGuid><b:Id>92</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:97ac13c4-147e-46b0-8603-5bc4a6cc4c79:de3f295a-bca5-4e40-a1f6-18648a39555c</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:54:50.9615591-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Flow Sniffing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Information Disclosure</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Information disclosure happens when the information can be read by an unauthorized party.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Data flowing across Binary biriectional may be sniffed by an attacker. Depending on what type of data an attacker can read, it may be used to attack other parts of the system or simply be a disclosure of information leading to compliance violations. Consider encrypting the data flow.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified that encryption keys flowing on the binary connection between File API and KMS could be intercepted. My mitigation was encrypted internal service connections and envelope encryption — file keys are themselves encrypted by a master key stored securely in KMS. (OWASP Top 10, owasp.org, 2021)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary biriectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>de3f295a-bca5-4e40-a1f6-18648a39555c</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>I6</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D4290fd120-69d8-46a1-8b55-f5f0b4a8229d97ac13c4-147e-46b0-8603-5bc4a6cc4c79de3f295a-bca5-4e40-a1f6-18648a39555c</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>97ac13c4-147e-46b0-8603-5bc4a6cc4c79</b:FlowGuid><b:Id>93</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:97ac13c4-147e-46b0-8603-5bc4a6cc4c79:de3f295a-bca5-4e40-a1f6-18648a39555c</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:55:13.3055451-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Flow Binary Is Potentially Interrupted</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An external agent interrupts data flowing across a trust boundary in either direction.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value> Found that the binary data flow to KMS could be flooded to prevent encryption/decryption operations. My mitigation was KMS request rate limiting and caching of short-lived data encryption keys so every file operation does not require a live KMS call. (AWS Well-Architected Framework Security Pillar, aws.amazon.com, 2023)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary biriectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>de3f295a-bca5-4e40-a1f6-18648a39555c</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D4</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D5290fd120-69d8-46a1-8b55-f5f0b4a8229d97ac13c4-147e-46b0-8603-5bc4a6cc4c79de3f295a-bca5-4e40-a1f6-18648a39555c</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>97ac13c4-147e-46b0-8603-5bc4a6cc4c79</b:FlowGuid><b:Id>94</b:Id><b:InteractionKey>290fd120-69d8-46a1-8b55-f5f0b4a8229d:97ac13c4-147e-46b0-8603-5bc4a6cc4c79:de3f295a-bca5-4e40-a1f6-18648a39555c</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:55:29.9847273-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Store Inaccessible</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An external agent prevents access to a data store on the other side of the trust boundary.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Applied the same KMS availability controls as threat 93, with multi-region KMS replication ensuring key availability even if one region experiences a denial of service event. (AWS Well-Architected Framework Security Pillar, aws.amazon.com, 2023)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Binary biriectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>de3f295a-bca5-4e40-a1f6-18648a39555c</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D5</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S15ff87fa8-86d3-4a55-9f50-262e41fa71fc663b907d-10c2-4dcc-bb8a-7834c5bf1b84290fd120-69d8-46a1-8b55-f5f0b4a8229d</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>663b907d-10c2-4dcc-bb8a-7834c5bf1b84</b:FlowGuid><b:Id>95</b:Id><b:InteractionKey>5ff87fa8-86d3-4a55-9f50-262e41fa71fc:663b907d-10c2-4dcc-bb8a-7834c5bf1b84:290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:55:48.4732207-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing the API Gateway Process</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>API Gateway may be spoofed by an attacker and this may lead to unauthorized access to File Upload/Download API. Consider using a standard authentication mechanism to identify the source process.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified that the API Gateway could be targeted by a spoofed internal service trying to bypass authentication. My mitigation was mutual TLS between all internal services and the API Gateway so only verified services can communicate through it. (OWASP Threat Modeling Process, owasp.org, 2024)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>R65ff87fa8-86d3-4a55-9f50-262e41fa71fc663b907d-10c2-4dcc-bb8a-7834c5bf1b84290fd120-69d8-46a1-8b55-f5f0b4a8229d</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>663b907d-10c2-4dcc-bb8a-7834c5bf1b84</b:FlowGuid><b:Id>96</b:Id><b:InteractionKey>5ff87fa8-86d3-4a55-9f50-262e41fa71fc:663b907d-10c2-4dcc-bb8a-7834c5bf1b84:290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:56:04.3696413-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential Data Repudiation by File Upload/Download API</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Repudiation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Repudiation threats involve an adversary denying that something happened.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>File Upload/Download API claims that it did not receive data from a source outside the trust boundary. Consider using logging or auditing to record the source, time, and summary of the received data.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Found that File Upload/Download API activity must be fully logged to prevent users from denying file operations. All upload, download, and delete events are captured in the immutable audit log with user ID, file ID, timestamp, and source IP. (OWASP Threat Modeling Process, owasp.org, 2024)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>R6</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D35ff87fa8-86d3-4a55-9f50-262e41fa71fc663b907d-10c2-4dcc-bb8a-7834c5bf1b84290fd120-69d8-46a1-8b55-f5f0b4a8229d</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>663b907d-10c2-4dcc-bb8a-7834c5bf1b84</b:FlowGuid><b:Id>97</b:Id><b:InteractionKey>5ff87fa8-86d3-4a55-9f50-262e41fa71fc:663b907d-10c2-4dcc-bb8a-7834c5bf1b84:290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:56:26.4653515-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential Process Crash or Stop for File Upload/Download API</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>File Upload/Download API crashes, halts, stops or runs slowly; in all cases violating an availability metric.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified that the File Upload/Download API is a high-value DoS target due to its resource-intensive operations. My mitigation was the 100MB file size cap, API Gateway throttling, and Cloudflare/AWS Shield DDoS protection at the edge. (AWS Well-Architected Framework Security Pillar, aws.amazon.com, 2023)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D3</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D45ff87fa8-86d3-4a55-9f50-262e41fa71fc663b907d-10c2-4dcc-bb8a-7834c5bf1b84290fd120-69d8-46a1-8b55-f5f0b4a8229d</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>663b907d-10c2-4dcc-bb8a-7834c5bf1b84</b:FlowGuid><b:Id>98</b:Id><b:InteractionKey>5ff87fa8-86d3-4a55-9f50-262e41fa71fc:663b907d-10c2-4dcc-bb8a-7834c5bf1b84:290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:57:01.153552-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Flow HTTPS Is Potentially Interrupted</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An external agent interrupts data flowing across a trust boundary in either direction.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Applied CDN/WAF HTTPS flood protection to cover the external-facing connection to the File Upload/Download API, ensuring volumetric attacks are absorbed before reaching the application layer. (AWS Well-Architected Framework Security Pillar, aws.amazon.com, 2023)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D4</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E65ff87fa8-86d3-4a55-9f50-262e41fa71fc663b907d-10c2-4dcc-bb8a-7834c5bf1b84290fd120-69d8-46a1-8b55-f5f0b4a8229d</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>663b907d-10c2-4dcc-bb8a-7834c5bf1b84</b:FlowGuid><b:Id>99</b:Id><b:InteractionKey>5ff87fa8-86d3-4a55-9f50-262e41fa71fc:663b907d-10c2-4dcc-bb8a-7834c5bf1b84:290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:57:18.2086808-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>File Upload/Download API May be Subject to Elevation of Privilege Using Remote Code Execution</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>API Gateway may be able to remotely execute code for File Upload/Download API.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Found that a File Upload/Download API vulnerability could be exploited to gain API Gateway-level access. My mitigation was strict input validation, MIME-type magic byte checking, sandboxed file processing, and storing all files outside the web root to prevent server-side code execution. (OWASP Top 10, owasp.org, 2021)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E6</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E75ff87fa8-86d3-4a55-9f50-262e41fa71fc663b907d-10c2-4dcc-bb8a-7834c5bf1b84290fd120-69d8-46a1-8b55-f5f0b4a8229d</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>HERON_ASV_AI\lilu</b:ChangedBy><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>663b907d-10c2-4dcc-bb8a-7834c5bf1b84</b:FlowGuid><b:Id>100</b:Id><b:InteractionKey>5ff87fa8-86d3-4a55-9f50-262e41fa71fc:663b907d-10c2-4dcc-bb8a-7834c5bf1b84:290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-16T01:57:33.2008662-06:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Elevation by Changing the Execution Flow in File Upload/Download API</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An attacker may pass data into File Upload/Download API in order to change the flow of program execution within File Upload/Download API to the attacker's choosing.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>Identified that an attacker exploiting the File API could attempt OS-level privilege escalation. My mitigation was sandboxed file processing with ClamAV antivirus scanning and a least-privilege service account for the File API process itself. (Microsoft STRIDE Threat Modeling Framework, learn.microsoft.com, 2022)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>5ff87fa8-86d3-4a55-9f50-262e41fa71fc</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>290fd120-69d8-46a1-8b55-f5f0b4a8229d</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E7</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S1832b5c7f-fd8d-4c47-af6b-ea0fd006da0145448a19-eeda-4947-ab9c-1129f17395744be9d095-d0d8-4a18-88a4-d518f1fc04ac</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>45448a19-eeda-4947-ab9c-1129f1739574</b:FlowGuid><b:Id>101</b:Id><b:InteractionKey>832b5c7f-fd8d-4c47-af6b-ea0fd006da01:45448a19-eeda-4947-ab9c-1129f1739574:4be9d095-d0d8-4a18-88a4-d518f1fc04ac</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing the Load Balancer Process</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Load Balancer may be spoofed by an attacker and this may lead to unauthorized access to Access Control. Consider using a standard authentication mechanism to identify the source process.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>832b5c7f-fd8d-4c47-af6b-ea0fd006da01</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>4be9d095-d0d8-4a18-88a4-d518f1fc04ac</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>R6832b5c7f-fd8d-4c47-af6b-ea0fd006da0145448a19-eeda-4947-ab9c-1129f17395744be9d095-d0d8-4a18-88a4-d518f1fc04ac</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>45448a19-eeda-4947-ab9c-1129f1739574</b:FlowGuid><b:Id>102</b:Id><b:InteractionKey>832b5c7f-fd8d-4c47-af6b-ea0fd006da01:45448a19-eeda-4947-ab9c-1129f1739574:4be9d095-d0d8-4a18-88a4-d518f1fc04ac</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential Data Repudiation by Access Control</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Repudiation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Repudiation threats involve an adversary denying that something happened.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Access Control claims that it did not receive data from a source outside the trust boundary. Consider using logging or auditing to record the source, time, and summary of the received data.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>832b5c7f-fd8d-4c47-af6b-ea0fd006da01</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>4be9d095-d0d8-4a18-88a4-d518f1fc04ac</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>R6</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D3832b5c7f-fd8d-4c47-af6b-ea0fd006da0145448a19-eeda-4947-ab9c-1129f17395744be9d095-d0d8-4a18-88a4-d518f1fc04ac</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy i:nil="true"/><b:DrawingSurfaceGuid>a53d215e-c270-409d-bfb9-bb6623dfdd65</b:DrawingSurfaceGuid><b:FlowGuid>45448a19-eeda-4947-ab9c-1129f1739574</b:FlowGuid><b:Id>103</b:Id><b:InteractionKey>832b5c7f-fd8d-4c47-af6b-ea0fd006da01:45448a19-eeda-4947-ab9c-1129f1739574:4be9d095-d0d8-4a18-88a4-d518f1fc04ac</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>0001-01-01T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential Process Crash or Stop for Access Control</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Access Control crashes, halts, stops or runs slowly; in all cases violating an availability metric.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>HTTPS bidirectional</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>832b5c7f-fd8d-4c47-af6b-ea0fd006da01</b:SourceGuid><b:State>AutoGenerated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>4be9d095-d0d8-4a18-88a4-d518f1fc04ac</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D3</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D4832b5c7f-fd8d-4c47-af6b-ea0fd006da0145448a19-eeda-4947-ab9c-1129f17395744be9d095-d0d8-4a18-88a4-d518f1fc04ac</a:Key><a:Value xmlns:b=